 in sliding window\n      5  unique_ports      – distinct dst ports in recent window\n      6  syn_ratio         – fraction of SYN-flagged packets in window\n      7  connection_count  – unique (src,dst) port pairs\n\n    Labels: 0=Normal (~65%), 1=Attack (~35%)\n    Each node sees ONLY its speciality attack type.\n    Label noise: 10% random flips (sensor/labelling errors).\n\n    Node specialities:\n      Node 1: syn_flood    high packet rate, high SYN ratio, small packets\n      Node 2: port_scan    many unique ports, sequential dst ports, SYN flag\n      Node 3: suspicious   maximally overlapping features with normal traffic\n    \"\"\"\n    rng = np.random.default_rng(seed)\n    X, y = [], []\n    for _ in range(n):\n        if rng.random() < 0.65:\n            feat = [\n                float(rng.integers(300, 1500)),\n                float(rng.integers(8000, 65535)),\n                float(rng.choice([80,443,22,3306,8080,53,25,110])),\n                float(rng.random() < 0.07),\n                float(rng.uniform(1, 10)),\n                float(rng.uniform(1, 8)),\n                float(rng.uniform(0, 0.18)),\n                float(rng.uniform(1, 12)),\n            ]\n            label = 0\n        else:\n            if speciality == 'syn_flood':\n                feat = [\n                    float(rng.integers(55, 160)),\n                    float(rng.integers(1024, 65535)),\n                    float(rng.choice([80, 443])),\n                    1.0,\n                    float(rng.uniform(25, 80)),\n                    float(rng.uniform(1, 4)),\n                    float(rng.uniform(0.72, 1.0)),\n                    float(rng.uniform(30, 100)),\n                ]\n            elif speciality == 'port_scan':\n                feat = [\n                    float(rng.integers(60, 150)),\n                    float(rng.integers(50000, 65535)),\n                    float(rng.integers(1, 1025)),\n                    1.0,\n                    float(rng.uniform(18, 55)),\n                    float(rng.uniform(18, 40)),\n                    float(rng.uniform(0.70, 1.0)),\n                    float(rng.uniform(15, 50)),\n                ]\n            else:  # suspicious – maximally overlaps with normal\n                feat = [\n                    float(rng.integers(200, 900)),\n                    float(rng.integers(5000, 65535)),\n                    float(rng.choice([23,135,139,445,1433,3389])),\n                    float(rng.random() < 0.35),\n                    float(rng.uniform(4, 18)),\n                    float(rng.uniform(4, 14)),\n                    float(rng.uniform(0.12, 0.50)),\n                    float(rng.uniform(4, 20)),\n                ]\n            label = 1\n        X.append(feat); y.append(label)\n\n    X = np.array(X, dtype=float); y = np.array(y, dtype=int)\n    noise_idx = rng.choice(n, int(noise*n), replace=False)\n    y[noise_idx] = 1 - y[noise_idx]\n    return X, y\n\n\ndef generate_balanced_test(n=500, seed=99):\n    \"\"\"Test set has ALL attack types equally – exposes node specialisation gaps.\"\"\"\n    rng = np.random.default_rng(seed)\n    X, y = [], []\n    atypes = ['syn_flood','port_scan','suspicious']\n    for i in range(n):\n        if rng.random() < 0.60:\n            feat = [float(rng.integers(300,1500)), float(rng.integers(8000,65535)),\n                    float(rng.choice([80,443,22,3306,53])), float(rng.random()<0.07),\n                    float(rng.uniform(1,10)), float(rng.uniform(1,8)),\n                    float(rng.uniform(0,0.18)), float(rng.uniform(1,12))]\n            label = 0\n        else:\n            at = atypes[i % 3]\n            if at == 'syn_flood':\n                feat = [float(rng.integers(55,160)), float(rng.integers(1024,65535)),\n                        float(rng.choice([80,443])), 1.0,\n                        float(rng.uniform(25,80)), float(rng.uniform(1,4)),\n                        float(rng.uniform(0.72,1.0)), float(rng.uniform(30,100))]\n            elif at == 'port_scan':\n                feat = [float(rng.integers(60,150)), float(rng.integers(50000,65535)),\n                        float(rng.integers(1,1025)), 1.0,\n                        float(rng.uniform(18,55)), float(rng.uniform(18,40)),\n                        float(rng.uniform(0.70,1.0)), float(rng.uniform(15,50))]\n            else:\n                feat = [float(rng.integers(200,900)), float(rng.integers(5000,65535)),\n                        float(rng.choice([23,135,139,445,1433,3389])), float(rng.random()<0.35),\n                        float(rng.uniform(4,18)), float(rng.uniform(4,14)),\n                        float(rng.uniform(0.12,0.50)), float(rng.uniform(4,20))]\n            label = 1\n        X.append(feat); y.append(label)\n\n    X = np.array(X,dtype=float); y = np.array(y,dtype=int)\n    ni = rng.choice(n, int(0.05*n), replace=False); y[ni] = 1-y[ni]\n    return X, y\n\n\n# Build datasets\nSPECIALITIES = ['syn_flood', 'port_scan', 'suspicious']\nraw_datasets  = [generate_node_dataset(630, seed=i, speciality=SPECIALITIES[i]) for i in range(3)]\n\n# Global normalisation (all nodes combined)\nX_all_raw = np.vstack([d[0] for d in raw_datasets])\nMU_G  = X_all_raw.mean(0)\nSIG_G = X_all_raw.std(0) + 1e-6\n\nnode_datasets = [((X-MU_G)/SIG_G, y) for X,y in raw_datasets]\nX_test_raw, y_test = generate_balanced_test(500, seed=99)\nX_test = (X_test_raw - MU_G) / SIG_G\n\nprint('='*64)\nprint('  DATASET DESCRIPTION')\nprint('='*64)\nprint(f'  Total training samples : {sum(len(d[1]) for d in raw_datasets)} (3 nodes x 630)')\nprint(f'  Test samples           : 500 (all three attack types equally)')\nprint(f'  Features               : 8 network traffic features')\nprint(f'  Normalisation          : global z-score across all nodes')\nprint(f'  Label noise            : 10% random flips (train), 5% (test)')\nprint()\nprint(f'  Node | Speciality      | Normal | Attack | Total')\nprint(f'  ─────┼─────────────────┼────────┼────────┼──────')\nfor i,((X,y),sp) in