}],"execution_count":2},{"cell_type":"markdown","source":"## 2 · Lightweight MLP (81 Parameters)","metadata":{}},{"cell_type":"code","source":"class LightweightMLP:\n    \"\"\"\n    Architecture  : 8 -> 8 -> 1\n    Layer 1 weights: 8x8 = 64 | Layer 1 biases: 8\n    Layer 2 weights: 8x1 =  8 | Layer 2 biases: 1\n    TOTAL: 81 parameters | Storage (float32): 324 B = 0.32 kB\n    Inference FLOPs: ~144 multiply-adds per sample\n    \"\"\"\n    def __init__(self, seed=None):\n        rng = np.random.default_rng(seed)\n        self.W1 = rng.standard_normal((8,8)) * np.sqrt(2/8)\n        self.b1 = np.zeros(8)\n        self.W2 = rng.standard_normal((8,1)) * np.sqrt(2/8)\n        self.b2 = np.zeros(1)\n\n    @staticmethod\n    def _relu(z):    return np.maximum(0, z)\n    @staticmethod\n    def _sigmoid(z): return 1/(1+np.exp(-np.clip(z,-500,500)))\n    @staticmethod\n    def _relu_g(z):  return (z>0).astype(float)\n\n    def _forward(self, X):\n        self._z1 = X@self.W1+self.b1; self._a1 = self._relu(self._z1)\n        self._z2 = self._a1@self.W2+self.b2; self._a2 = self._sigmoid(self._z2)\n        return self._a2\n\n    def predict_proba(self, X): return self._forward(X).ravel()\n    def predict(self, X):       return (self.predict_proba(X)>=0.5).astype(int)\n\n    def _bce(self, yh, y):\n        e=1e-9; return -np.mean(y*np.log(yh+e)+(1-y)*np.log(1-yh+e))\n\n    def _backward(self, X, y):\n        N=len(y); y=y.reshape(-1,1)\n        d2=(self._a2-y)/N\n        dW2=self._a1.T@d2; db2=d2.sum(0)\n        d1=(d2@self.W2.T)*self._relu_g(self._z1)\n        dW1=X.T@d1; db1=d1.sum(0)\n        return dW1,db1,dW2,db2\n\n    def fit(self, X, y, X_val=None, y_val=None, epochs=200, lr=0.05, batch=32):\n        N=len(y); hist={'train_loss':[],'val_loss':[],'val_acc':[]}\n        for ep in range(epochs):\n            perm=np.random.permutation(N)\n            for s in range(0,N,batch):\n                b=perm[s:s+batch]\n                self._forward(X[b]); dW1,db1,dW2,db2=self._backward(X[b],y[b])\n                self.W1-=lr*dW1; self.b1-=lr*db1; self.W2-=lr*dW2; self.b2-=lr*db2\n            hist['train_loss'].append(self._bce(self._forward(X).ravel(),y))\n            if X_val is not None:\n                vp=self._forward(X_val).ravel()\n                hist['val_loss'].append(self._bce(vp,y_val))\n                hist['val_acc'].append(np.mean((vp>=0.5).astype(int)==y_val))\n        return hist\n\n    def local_train(self, X, y, epochs=5, lr=0.05, batch=32):\n        \"\"\"Fewer epochs per FL round so federation drives the improvement.\"\"\"\n        return self.fit(X, y, epochs=epochs, lr=lr, batch=batch)\n\n    def get_flat(self): return np.concatenate([self.W1.ravel(),self.b1,self.W2.ravel(),self.b2])\n    def set_flat(self, w):\n        self.W1=w[:64].reshape(8,8); self.b1=w[64:72]\n        self.W2=w[72:80].reshape(8,1); self.b2=w[80:81]\n\n    def parameter_report(self):\n        print('\\n'+'='*52)\n        print('  MODEL ARCHITECTURE – Lightweight MLP')\n        print('='*52)\n        print('  Architecture         : 8 -> 8 -> 1')\n        print('  Activation (hidden)  : ReLU')\n        print('  Activation (output)  : Sigmoid')\n        print('  Loss                 : Binary cross-entropy')\n        print('  Optimiser            : Mini-batch SGD  (lr=0.05)')\n        print('-'*52)\n        print('  Layer 1 weights : 8x8 = 64')\n        print('  Layer 1 biases  :   8 =  8')\n        print('  Layer 2 weights : 8x1 =  8')\n        print('  Layer 2 biases  :   1 =  1')\n        print('-'*52)\n        print('  TOTAL PARAMETERS   = 81')\n        print('  Storage (float32)  = 81x4 B = 324 B = 0.316 kB')\n        print('  Inference FLOPs    = ~144 multiply-adds/sample')\n        print('='*52)\n\n\nmodel = LightweightMLP(seed=42)\nmodel.parameter_report()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-25T01:46:57.369214Z","iopub.execute_input":"2026-02-25T01:46:57.369989Z","iopub.status.idle":"2026-02-25T01:46:57.391178Z","shell.execute_reply.started":"2026-02-25T01:46:57.369956Z","shell.execute_reply":"2026-02-25T01:46:57.389898Z"}},"outputs":[{"name":"stdout","text":"\n====================================================\n  MODEL ARCHITECTURE – Lightweight MLP\n====================================================\n  Architecture         : 8 -> 8 -> 1\n  Activation (hidden)  : ReLU\n  Activation (output)  : Sigmoid\n  Loss                 : Binary cross-entropy\n  Optimiser            : Mini-batch SGD  (lr=0.05)\n----------------------------------------------------\n  Layer 1 weights : 8x8 = 64\n  Layer 1 biases  :   8 =  8\n  Layer 2 weights : 8x1 =  8\n  Layer 2 biases  :   1 =  1\n----------------------------------------------------\n  TOTAL PARAMETERS   = 81\n  Storage (float32)  = 81x4 B = 324 B = 0.316 kB\n  Inference FLOPs    = ~144 multiply-adds/sample\n====================================================\n","output_type":"stream"}],"execution_count":3},{"cell_type":"markdown","source":"## 3 · Train & Evaluate Single Node","metadata":{}},{"cell_type":"code","source":"def eval_metrics(model, X, y):\n    yp=model.predict(X)\n    tp=int(((y==1)&(yp==1)).sum()); fp=int(((y==0)&(yp==1)).sum())\n    fn=int(((y==1)&(yp==0)).sum()); tn=int(((y==0)&(yp==0)).sum())\n    acc=(tp+tn)/(tp+fp+fn+tn)\n    prec=tp/(tp+fp) if (tp+fp)>0 else 0\n    rec=tp/(tp+fn) if (tp+fn)>0 else 0\n    f1=2*prec*rec/(prec+rec) if (prec+rec)>0 else 0\n    loss=-np.mean(y*np.log(model.predict_proba(X)+1e-9)\n                 +(1-y)*np.log(1-model.predict_proba(X)+1e-9))\n    return dict(tp=tp,fp=fp,fn=fn,tn=tn,accuracy=acc,\n                precision=prec,recall=rec,f1=f1,loss=loss)\n\n\nXtr, ytr = node_datasets[0]\nnv = int(0.2*len(ytr))\nhist = model.fit(Xtr[nv:], ytr[nv:], X_val=Xtr[:nv], y_val=ytr[:nv], epochs=200)\ntest_m = eval_metrics(model, X_test, y_test)\n\nprint(f'Final val acc  : {hist[\"val_acc\"][-1]*100:.2f}%')\nprint(f'Test accuracy  : {test_m[\"accuracy\"]*100:.2f}% (pre-federation, syn_flo