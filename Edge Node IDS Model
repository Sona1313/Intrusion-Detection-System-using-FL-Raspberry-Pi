","\n","--- Progress: 30/50 packets processed ---\n","\n","[031] ⚠️  ANOMALY | Confidence: 0.700 | Port: 53 | Size: 1284B | Flags: \n","[032] ⚠️  ANOMALY | Confidence: 1.000 | Port: 80 | Size: 60B | Flags: S\n","[033] ⚠️  ANOMALY | Confidence: 0.800 | Port: 443 | Size: 589B | Flags: FA\n","[034] ⚠️  ANOMALY | Confidence: 0.800 | Port: 22 | Size: 1068B | Flags: SA\n","[035] ⚠️  ANOMALY | Confidence: 0.700 | Port: 21 | Size: 1237B | Flags: \n","[036] ⚠️  ANOMALY | Confidence: 0.700 | Port: 22 | Size: 600B | Flags: \n","[037] ⚠️  ANOMALY | Confidence: 0.600 | Port: 22 | Size: 776B | Flags: FA\n","[038] ⚠️  ANOMALY | Confidence: 0.700 | Port: 3306 | Size: 827B | Flags: FA\n","[039] ⚠️  ANOMALY | Confidence: 0.900 | Port: 8080 | Size: 632B | Flags: A\n","[040] ⚠️  ANOMALY | Confidence: 0.800 | Port: 3306 | Size: 494B | Flags: A\n","\n","--- Progress: 40/50 packets processed ---\n","\n","[041] ⚠️  ANOMALY | Confidence: 1.000 | Port: 139 | Size: 227B | Flags: S\n","[042] ⚠️  ANOMALY | Confidence: 0.600 | Port: 443 | Size: 761B | Flags: A\n","[043] ⚠️  ANOMALY | Confidence: 0.600 | Port: 443 | Size: 1213B | Flags: \n","[044] ⚠️  ANOMALY | Confidence: 0.800 | Port: 443 | Size: 444B | Flags: FA\n","[045] ⚠️  ANOMALY | Confidence: 0.700 | Port: 3306 | Size: 1272B | Flags: A\n","[046] ⚠️  ANOMALY | Confidence: 0.700 | Port: 3306 | Size: 758B | Flags: A\n","[047] ⚠️  ANOMALY | Confidence: 0.700 | Port: 443 | Size: 598B | Flags: PA\n","[048] ⚠️  ANOMALY | Confidence: 0.800 | Port: 21 | Size: 442B | Flags: PA\n","[049] ⚠️  ANOMALY | Confidence: 0.600 | Port: 53 | Size: 1140B | Flags: A\n","[050] ⚠️  ANOMALY | Confidence: 0.600 | Port: 22 | Size: 973B | Flags: PA\n","\n","--- Progress: 50/50 packets processed ---\n","\n","\n","======================================================================\n","[Node edge_node_1] ML DETECTION SUMMARY REPORT\n","======================================================================\n","Model Type:                Random Forest Classifier\n","Training Samples:          500\n","Test Accuracy:             100.00%\n","Test Precision:            100.00%\n","Test Recall:               100.00%\n","Test F1-Score:             100.00%\n","\n","Runtime Performance:\n","Total Packets Analyzed:    50\n","Normal Traffic:            9 (18.0%)\n","Anomalies Detected:        41 (82.0%)\n","======================================================================\n","\n","📤 Sending ML model update to FL Server...\n","\n","⚠️  Server not available - Update saved locally\n"]}],"source":["\"\"\"\n","Random Forest-based Intrusion Detection System for Raspberry Pi 4\n","Optimized for resource-constrained devices with actual ML model\n","Memory footprint: ~15-20MB, CPU usage: <15% on RPi4\n","\"\"\"\n","\n","import numpy as np\n","import json\n","import time\n","import random\n","from collections import deque\n","import socket\n","import pickle\n","\n","class SimpleRandomForest:\n","    \"\"\"\n","    Lightweight Random Forest implementation optimized for edge devices\n","    Uses simplified decision trees with limited depth\n","    \"\"\"\n","    \n","    def __init__(self, n_trees=10, max_depth=5, min_samples_split=10):\n","        self.n_trees = n_trees\n","        self.max_depth = max_depth\n","        self.min_samples_split = min_samples_split\n","        self.trees = []\n","        self.feature_importances_ = None\n","        \n","    class DecisionTree:\n","        def __init__(self, max_depth, min_samples_split):\n","            self.max_depth = max_depth\n","            self.min_samples_split = min_samples_split\n","            self.tree = None\n","            \n","        def _gini_impurity(self, y):\n","            \"\"\"Calculate Gini impurity\"\"\"\n","            if len(y) == 0:\n","                return 0\n","            classes, counts = np.unique(y, return_counts=True)\n","            probabilities = counts / len(y)\n","            return 1 - np.sum(probabilities ** 2)\n","        \n","        def _split(self, X, y, feature_idx, threshold):\n","            \"\"\"Split dataset based on feature and threshold\"\"\"\n","            left_mask = X[:, feature_idx] <= threshold\n","            right_mask = ~left_mask\n","            return (X[left_mask], y[left_mask]), (X[right_mask], y[right_mask])\n","        \n","        def _best_split(self, X, y):\n","            \"\"\"Find best split for the data\"\"\"\n","            best_gini = float('inf')\n","            best_split = None\n","            n_features = X.shape[1]\n","            \n","            # Try random subset of features (for Random Forest diversity)\n","            n_features_to_try = max(1, int(np.sqrt(n_features)))\n","            features_to_try = np.random.choice(n_features, n_features_to_try, replace=False)\n","            \n","            for feature_idx in features_to_try:\n","                thresholds = np.percentile(X[:, feature_idx], [25, 50, 75])\n","                \n","                for threshold in thresholds:\n","                    (X_left, y_left), (X_right, y_right) = self._split(X, y, feature_idx, threshold)\n","                    \n","                    if len(y_left) == 0 or len(y_right) == 0:\n","                        continue\n","                    \n","                    # Calculate weighted Gini impurity\n","                    n = len(y)\n","                    gini = (len(y_left) / n * self._gini_impurity(y_left) +\n","                           len(y_right) / n * self._gini_impurity(y_right))\n","                    \n","                    if gini < best_gini:\n","                        best_gini = gini\n","                        best_split = {\n","                            'feature_idx': feature_idx,\n","                            'threshold': threshold,\n","                            'gini': gini\n","                        }\n","            \n","            return best_split\n","        \n","        def _build_tree(self, X, y, depth=0):\n","            \"\"\"Recursively build decision tree\"\"\"\n","            n_samples, n_features = X.shape\n","            n_classes = len(np.unique(y))\n","            \n","            # Stopping criteria\n","            if (depth >= self.max_depth or \n","                n_samples < self.min_samples_split or \n","                n_classes == 1):\n","                leaf_value = np.bincount(y.astype(int)).argmax()\n","                return {'type': 'leaf', 'value': leaf_value}\n","            \n","            # Find best split\n","            best_split = self._best_split(X, y)\n","            \n","            if best_split is None:\n","                leaf_value = np.bincount(y.astype(int)).argmax()\n","                return {'type': 'leaf', 'value': leaf_value}\n","            \n","            # Split data\n","            (X_left, y_left), (X_right, y_right) = self._split(\n","                X, y, best_split['feature_idx'], best_split['threshold']\n","            )\n","            \n","            # Build subtrees\n","            left_subtree = self._build_tree(X_left, y_left, depth + 1)\n","            right_subtree = self._build_tree(X_right, y_right, depth + 1)\n","            \n","            return {\n","                'type': 'node',\n","                'feature_idx': best_split['feature_idx'],\n","                'threshold': best_split['threshold'],\n","                'left': left_subtree,\n","                'right': right_subtree\n","            }\n","        \n","        def fit(self, X, y):\n","            \"\"\"Train the decision tree\"\"\"\n","            self.tree = self._build_tree(X, y)\n","            return self\n","        \n","        def _predict_sample(self, x, tree):\n","            \"\"\"Predict single sample\"\"\"\n","            if tree['type'] == 'leaf':\n","                return tree['value']\n","            \n","            if x[tree['feature_idx']] <= tree['threshold']:\n","                return self._predict_sample(x, tree['left'])\n","            else:\n","                return self._predict_sample(x, tree['right'])\n","        \n","        def predict(self, X):\n","            \"\"\"Predict multiple samples\"\"\"\n","            return np.array([self._predict_sample(x, self.tree) for x in X])\n","    \n","    def fit(self, X, y):\n","        \"\"\"Train Random Forest\"\"\"\n","        self.trees = []\n","        n_samples = len(X)\n","        \n","        for i in range(self.n_trees):\n","            # Bootstrap sampling\n","            indices = np.random.choice(n_samples, n_samples, replace=True)\n","            X_bootstrap = X[indices]\n","            y_bootstrap = y[indices]\n","            \n","            # Train tree\n","            tree = self.DecisionTree(self.max_depth, self.min_samples_split)\n","            tree.fit(X_bootstrap, y_bootstrap)\n","            self.trees.append(tree)\n","            \n","        return self\n","    \n","    def predict(self, X):\n","        \"\"\"Predict using majority voting\"\"\"\n","        predictions = np.array([tree.predict(X) for tree in self.trees])\n","        # Majority vote\n","        return np.apply_along_axis(\n","            lambda x: np.bincount(x.astype(int)).argmax(), \n","            axis=0, \n","            arr=predictions\n","        )\n","    \n","    def predict_proba(self, X):\n","        \"\"\"Predict probability (anomaly score)\"\"\"\n","        predictions = np.array([tree.predict(X) for tree in self.trees])\n","        # Calculate proportion of trees predicting anomaly\n","        return np.mean(predictions, axis=0)\n","\n","\n","class MLBasedIDS:\n","    \"\"\"\n","    Machine Learning-based IDS using Random Forest\n","    Suitable for Raspberry Pi 4 with actual ML model\n","    \"\"\"\n","    \n","    def __init__(self, node_id, window_size=100):\n","        self.node_id = node_id\n","        self.window_size = window_size\n","        self.traffic_buffer = deque(maxlen=window_size)\n","        \n","        # Initialize Random Forest model (lightweight configuration)\n","        self.model = SimpleRandomForest(n_trees=10, max_depth=5, min_samples_split=10)\n","        self.is_trained = False\n","        \n","        # Feature statistics for normalization\n","        self.feature_stats = {\n","            'mean': None,\n","            'std': None\n","        }\n","        \n","        # Statistics tracking\n","        self.stats = {\n","            'total_packets': 0,\n","            'anomalies_detected': 0,\n","            'training_samples': 0\n","        }\n","        \n","        # Initial training with synthetic data\n","        self._bootstrap_training()\n","        \n","    def _bootstrap_training(self):\n","        \"\"\"Bootstrap the model with synthetic training data using 50-15-35 split\"\"\"\n","        print(f\"[Node {self.node_id}] Bootstrapping ML model with synthetic data...\")\n","        print(f\"Using 50% train, 15% validation, 35% test split\\n\")\n","        \n","        # Generate synthetic training data (1000 samples total)\n","        X_all, y_all = self._generate_training_data(1000)\n","        \n","        # 50-15-35 split\n","        n_samples = len(X_all)\n","        n_train = int(0.50 * n_samples)  # 500 samples\n","        n_val = int(0.15 * n_samples)    # 150 samples\n","        n_test = n_samples - n_train - n_val  # 350 samples\n","        \n","        # Shuffle data\n","        indices = np.arange(n_samples)\n","        np.random.shuffle(indices)\n","        \n","        # Split indices\n","        train_idx = indices[:n_train]\n","        val_idx = indices[n_train:n_train + n_val]\n","        test_idx = indices[n_train + n_val:]\n","        \n","        # Create splits\n","        X_train, y_train = X_all[train_idx], y_all[train_idx]\n","        X_val, y_val = X_all[val_idx], y_all[val_idx]\n","        X_test, y_test = X_all[test_idx], y_all[test_idx]\n","        \n","        print(f\"Dataset Split:\")\n","        print(f\"  Training:   {len(X_train)} samples ({len(X_train)/n_samples*100:.1f}%)\")\n","        print(f\"  Validation: {len(X_val)} samples ({len(X_val)/n_samples*100:.1f}%)\")\n","        print(f\"  Test:       {len(X_test)} samples ({len(X_test)/n_samples*100:.1f}%)\")\n","        print()\n","        \n","        # Calculate feature statistics for normalization (only from training data!)\n","        self.feature_stats['mean'] = np.mean(X_train, axis=0)\n","        self.feature_stats['std'] = np.std(X_train, axis=0) + 1e-6\n","        \n","        # Normalize all splits using training statistics\n","        X_train_norm = (X_train - self.feature_stats['mean']) / self.feature_stats['std']\n","        X_val_norm = (X_val - self.feature_stats['mean']) / self.feature_stats['std']\n","        X_test_norm = (X_test - self.feature_stats['mean']) / self.feature_stats['std']\n","        \n","        # Train model\n","        print(f\"Training Random Forest model...\")\n","        self.model.fit(X_train_norm, y_train)\n","        self.is_trained = True\n","        self.stats['training_samples'] = len(X_train)\n","        \n","        # Validate model\n","        print(f\"\\nValidating model on validation set...\")\n","        val_predictions = self.model.predict(X_val_norm)\n","        val_accuracy = np.mean(val_predictions == y_val)\n","        val_precision, val_recall, val_f1 = self._calculate_metrics(y_val, val_predictions)\n","        \n","        print(f\"Validation Results:\")\n","        print(f\"  Accuracy:  {val_accuracy*100:.2f}%\")\n","        print(f\"  Precision: {val_precision*100:.2f}%\")\n","        print(f\"  Recall:    {val_recall*100:.2f}%\")\n","        print(f\"  F1-Score:  {val_f1*100:.2f}%\")\n","        \n","        # Test model\n","        print(f\"\\nTesting model on test set...\")\n","        test_predictions = self.model.predict(X_test_norm)\n","        test_accuracy = np.mean(test_predictions == y_test)\n","        test_precision, test_recall, test_f1 = self._calculate_metrics(y_test, test_predictions)\n","        \n","        print(f\"Test Results:\")\n","        print(f\"  Accuracy:  {test_accuracy*100:.2f}%\")\n","        print(f\"  Precision: {test_precision*100:.2f}%\")\n","        print(f\"  Recall:    {test_recall*100:.2f}%\")\n","        print(f\"  F1-Score:  {test_f1*100:.2f}%\")\n","        \n","        # Store metrics\n","        self.stats['validation_accuracy'] = val_accuracy\n","        self.stats['test_accuracy'] = test_accuracy\n","        self.stats['test_precision'] = test_precision\n","        self.stats['test_recall'] = test_recall\n","        self.stats['test_f1'] = test_f1\n","        \n","        print(f\"\\n✅ Model training complete!\\n\")\n","    \n","    def _generate_training_data(self, n_samples=1000):\n","        \"\"\"Generate synthetic training data for bootstrap\"\"\"\n","        X = []\n","        y = []\n","        \n","        for _ in range(n_samples):\n","            # 70% normal traffic\n","            if random.random() < 0.70:\n","                features = [\n","                    random.randint(400, 1500),  # packet_size\n","                    random.randint(10000, 65535),  # src_port\n","                    random.choice([80, 443, 22, 3306, 8080]),  # dst_port (normal)\n","                    0,  # syn_flag\n","                    random.randint(1, 5),  # packet_rate\n","                    random.randint(1, 5),  # unique_ports\n","                    random.uniform(0, 0.1),  # syn_ratio\n","                    random.randint(1, 10),  # connection_count\n","                ]\n","                label = 0  # Normal\n","            # 30% anomalous traffic\n","            else:\n","                attack_type = random.choice(['port_scan', 'syn_flood', 'suspicious'])\n","                \n","                if attack_type == 'port_scan':\n","                    features = [\n","                        64,  # small packet\n","                        54321,  # fixed src port\n","                        random.randint(1, 1024),  # scanning ports\n","                        1,  # SYN flag\n","                        random.randint(20, 50),  # high packet rate\n","                        random.randint(15, 30),  # many unique ports\n","                        random.uniform(0.8, 1.0),  # high SYN ratio\n","                        random.randint(20, 50),  # many connections\n","                    ]\n","                elif attack_type == 'syn_flood':\n","                    features = [\n","                        60,  # small packet\n","                        random.randint(1024, 65535),\n","                        80,  # target port\n","                        1,  # SYN flag\n","                        random.randint(30, 100),  # very high packet rate\n","                        random.randint(1, 3),  # few unique ports\n","                        random.uniform(0.9, 1.0),  # very high SYN ratio\n","                        random.randint(50, 100),  # many connections\n","                    ]\n","                else:  # suspicious port\n","                    features = [\n","                        random.randint(100, 500),\n","                        random.randint(10000, 65535),\n","                        random.choice([23, 135, 139, 445, 1433, 3389]),  # suspicious ports\n","                        random.choice([0, 1]),\n","                        random.randint(5, 20),  # moderate packet rate\n","                        random.randint(5, 15),  # moderate unique ports\n","                        random.uniform(0.2, 0.5),  # moderate SYN ratio\n","                        random.randint(5, 20),  # moderate connections\n","                    ]\n","                label = 1  # Anomaly\n","            \n","            X.append(features)\n","            y.append(label)\n","        \n","        return np.array(X), np.array(y)\n","    \n","    def _calculate_metrics(self, y_true, y_pred):\n","        \"\"\"Calculate precision, recall, and F1 score\"\"\"\n","        # True Positives, False Positives, False Negatives\n","        tp = np.sum((y_true == 1) & (y_pred == 1))\n","        fp = np.sum((y_true == 0) & (y_pred == 1))\n","        fn = np.sum((y_true == 1) & (y_pred == 0))\n","        \n","        # Precision: TP / (TP + FP)\n","        precision = tp / (tp + fp) if (tp + fp) > 0 else 0\n","        \n","        # Recall: TP / (TP + FN)\n","        recall = tp / (tp + fn) if (tp + fn) > 0 else 0\n","        \n","        # F1 Score: 2 * (Precision * Recall) / (Precision + Recall)\n","        f1 = 2 * (precision * recall) / (precision + recall) if (precision + recall) > 0 else 0\n","        \n","        return precision, recall, f1\n","    \n","    def extract_features(self, packet):\n","        \"\"\"Extract features from network packet\"\"\"\n","        # Add to buffer\n","        self.traffic_buffer.append(packet)\n","        \n","        if len(self.traffic_buffer) < 10:\n","            return None\n","        \n","        # Calculate window-based features\n","        recent_packets = list(self.traffic_buffer)[-20:]\n","        \n","        # Feature 1-2: Current packet info\n","        packet_size = packet.get('size', 0)\n","        src_port = packet.get('src_port', 0)\n","        dst_port = packet.get('dst_port', 0)\n","        \n","        # Feature 3: SYN flag\n","        syn_flag = 1 if 'S' in packet.get('flags', '') else 0\n","        \n","        # Feature 4: Packet rate (packets in last second)\n","        current_time = packet.get('timestamp', time.time())\n","        recent_1s = [p for p in recent_packets \n","                     if current_time - p.get('timestamp', 0) < 1.0]\n","        packet_rate = len(recent_1s)\n","        \n","        # Feature 5: Port diversity\n","        unique_ports = len(set(p.get('dst_port', 0) for p in recent_packets))\n","        \n","        # Feature 6: SYN ratio\n","        syn_count = sum(1 for p in recent_packets if 'S' in p.get('flags', ''))\n","        syn_ratio = syn_count / len(recent_packe