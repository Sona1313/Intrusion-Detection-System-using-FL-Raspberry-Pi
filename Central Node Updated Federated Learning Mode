    "def run_fl(n_rounds=5, local_epochs=5, lr=0.05):\n",
    "    gw = LightweightMLP(seed=7).get_flat()\n",
    "    hist = dict(rounds=[], acc=[], prec=[], rec=[], f1=[], loss=[],\n",
    "                tp=[], fp=[], fn=[], tn=[], node_losses=[])\n",
    "\n",
    "    print('='*70)\n",
    "    print('  FEDERATED LEARNING SIMULATION  –  FedAvg  (3 specialised nodes)')\n",
    "    print('='*70)\n",
    "    print(f'  Node 1: syn_flood specialist   Node 2: port_scan specialist')\n",
    "    print(f'  Node 3: suspicious specialist  Test: all attack types equally')\n",
    "    print('='*70)\n",
    "\n",
    "    for rnd in range(1, n_rounds+1):\n",
    "        print(f'\\n  ROUND {rnd}/{n_rounds}  ────────────────────────────────────────')\n",
    "        ws=[]; ns=[]; node_loss_this_round=[]\n",
    "\n",
    "        for i, (Xi, yi) in enumerate(node_datasets):\n",
    "            m=LightweightMLP(seed=i*100+rnd)\n",
    "            m.set_flat(gw.copy())\n",
    "            m.local_train(Xi, yi, epochs=local_epochs, lr=lr)\n",
    "            mi=eval_metrics(m,Xi,yi)\n",
    "            print(f'  Node {i+1} ({SPECIALITIES[i]:10}): '\n",
    "                  f'loss={mi[\"loss\"]:.4f}  '\n",
    "                  f'acc={mi[\"accuracy\"]*100:.1f}%  '\n",
    "                  f'rec={mi[\"recall\"]*100:.1f}%  '\n",
    "                  f'[{len(yi)} samples]')\n",
    "            ws.append(m.get_flat()); ns.append(len(yi))\n",
    "            node_loss_this_round.append(mi['loss'])\n",
    "\n",
    "        total=sum(ns)\n",
    "        gw = sum(w*(n/total) for w,n in zip(ws,ns))\n",
    "\n",
    "        gm=LightweightMLP(); gm.set_flat(gw)\n",
    "        gmet=eval_metrics(gm, X_test, y_test)\n",
    "\n",
    "        print(f'\\n  GLOBAL MODEL (test set):')\n",
    "        print(f'    Accuracy  : {gmet[\"accuracy\"]*100:.2f}%')\n",
    "        print(f'    Precision : {gmet[\"precision\"]*100:.2f}%')\n",
    "        print(f'    Recall    : {gmet[\"recall\"]*100:.2f}%')\n",
    "        print(f'    F1-Score  : {gmet[\"f1\"]*100:.2f}%')\n",
    "        print(f'    CE Loss   : {gmet[\"loss\"]:.4f}')\n",
    "        print(f'    TP={gmet[\"tp\"]}  FP={gmet[\"fp\"]}  FN={gmet[\"fn\"]}  TN={gmet[\"tn\"]}')\n",
    "\n",
    "        hist['rounds'].append(rnd)\n",
    "        hist['acc'].append(gmet['accuracy'])\n",
    "        hist['prec'].append(gmet['precision'])\n",
    "        hist['rec'].append(gmet['recall'])\n",
    "        hist['f1'].append(gmet['f1'])\n",
    "        hist['loss'].append(gmet['loss'])\n",
    "        hist['tp'].append(gmet['tp'])\n",
    "        hist['fp'].append(gmet['fp'])\n",
    "        hist['fn'].append(gmet['fn'])\n",
    "        hist['tn'].append(gmet['tn'])\n",
    "        hist['node_losses'].append(node_loss_this_round)\n",
    "\n",
    "    print('\\n'+'='*70)\n",
    "    print('  TRAINING COMPLETE')\n",
    "    print('='*70)\n",
    "    print(f'  Initial accuracy : {hist[\"acc\"][0]*100:.2f}%')\n",
    "    print(f'  Final   accuracy : {hist[\"acc\"][-1]*100:.2f}%')\n",
    "    print(f'  Total gain       : +{(hist[\"acc\"][-1]-hist[\"acc\"][0])*100:.1f} pp')\n",
    "    print(f'  Initial recall   : {hist[\"rec\"][0]*100:.2f}%')\n",
    "    print(f'  Final   recall   : {hist[\"rec\"][-1]*100:.2f}%')\n",
    "    print(f'  Loss  reduction  : {hist[\"loss\"][0]:.4f} -> {hist[\"loss\"][-1]:.4f}')\n",
    "    print('='*70)\n",
    "    return hist, gw\n",
    "\n",
    "\n",
    "history, final_weights = run_fl(n_rounds=5)"
   ]
