    "def generate_node_dataset(n=630, seed=0, speciality='syn_flood', noise=0.10):\n",
    "    \"\"\"\n",
    "    8-feature synthetic IoT traffic. Each node observes only its speciality attack.\n",
    "    suspicious class intentionally overlaps with normal to make classification hard.\n",
    "    10% label noise simulates sensor errors.\n",
    "    \"\"\"\n",
    "    rng = np.random.default_rng(seed)\n",
    "    X, y = [], []\n",
    "    for _ in range(n):\n",
    "        if rng.random() < 0.65:\n",
    "            feat = [float(rng.integers(300,1500)), float(rng.integers(8000,65535)),\n",
    "                    float(rng.choice([80,443,22,3306,8080,53,25,110])), float(rng.random()<0.07),\n",
    "                    float(rng.uniform(1,10)), float(rng.uniform(1,8)),\n",
    "                    float(rng.uniform(0,0.18)), float(rng.uniform(1,12))]\n",
    "            label = 0\n",
    "        else:\n",
    "            if speciality == 'syn_flood':\n",
    "                feat = [float(rng.integers(55,160)), float(rng.integers(1024,65535)),\n",
    "                        float(rng.choice([80,443])), 1.0,\n",
    "                        float(rng.uniform(25,80)), float(rng.uniform(1,4)),\n",
    "                        float(rng.uniform(0.72,1.0)), float(rng.uniform(30,100))]\n",
    "            elif speciality == 'port_scan':\n",
    "                feat = [float(rng.integers(60,150)), float(rng.integers(50000,65535)),\n",
    "                        float(rng.integers(1,1025)), 1.0,\n",
    "                        float(rng.uniform(18,55)), float(rng.uniform(18,40)),\n",
    "                        float(rng.uniform(0.70,1.0)), float(rng.uniform(15,50))]\n",
    "            else:   # suspicious – maximum overlap with normal\n",
    "                feat = [float(rng.integers(200,900)), float(rng.integers(5000,65535)),\n",
    "                        float(rng.choice([23,135,139,445,1433,3389])), float(rng.random()<0.35),\n",
    "                        float(rng.uniform(4,18)), float(rng.uniform(4,14)),\n",
    "                        float(rng.uniform(0.12,0.50)), float(rng.uniform(4,20))]\n",
    "            label = 1\n",
    "        X.append(feat); y.append(label)\n",
    "    X=np.array(X,dtype=float); y=np.array(y,dtype=int)\n",
    "    ni=rng.choice(n,int(noise*n),replace=False); y[ni]=1-y[ni]\n",
    "    return X, y\n",
    "\n",
    "\n",
    "def generate_balanced_test(n=500, seed=99):\n",
    "    \"\"\"Test set with all three attack types equally represented.\"\"\"\n",
    "    rng=np.random.default_rng(seed); X,y=[],[]\n",
    "    atypes=['syn_flood','port_scan','suspicious']\n",
    "    for i in range(n):\n",
    "        if rng.random()<0.60:\n",
    "            feat=[float(rng.integers(300,1500)),float(rng.integers(8000,65535)),\n",
    "                  float(rng.choice([80,443,22,3306,53])),float(rng.random()<0.07),\n",
    "                  float(rng.uniform(1,10)),float(rng.uniform(1,8)),\n",
    "                  float(rng.uniform(0,0.18)),float(rng.uniform(1,12))]\n",
    "            label=0\n",
    "        else:\n",
    "            at=atypes[i%3]\n",
    "            if at=='syn_flood':\n",
    "                feat=[float(rng.integers(55,160)),float(rng.integers(1024,65535)),\n",
    "                      float(rng.choice([80,443])),1.0,float(rng.uniform(25,80)),\n",
    "                      float(rng.uniform(1,4)),float(rng.uniform(0.72,1.0)),float(rng.uniform(30,100))]\n",
    "            elif at=='port_scan':\n",
    "                feat=[float(rng.integers(60,150)),float(rng.integers(50000,65535)),\n",
    "                      float(rng.integers(1,1025)),1.0,float(rng.uniform(18,55)),\n",
    "                      float(rng.uniform(18,40)),float(rng.uniform(0.70,1.0)),float(rng.uniform(15,50))]\n",
    "            else:\n",
    "                feat=[float(rng.integers(200,900)),float(rng.integers(5000,65535)),\n",
    "                      float(rng.choice([23,135,139,445,1433,3389])),float(rng.random()<0.35),\n",
    "                      float(rng.uniform(4,18)),float(rng.uniform(4,14)),\n",
    "                      float(rng.uniform(0.12,0.50)),float(rng.uniform(4,20))]\n",
    "            label=1\n",
    "        X.append(feat); y.append(label)\n",
    "    X=np.array(X,dtype=float); y=np.array(y,dtype=int)\n",
    "    ni=rng.choice(n,int(0.05*n),replace=False); y[ni]=1-y[ni]\n",
    "    return X, y\n",
    "\n",
    "\n",
    "SPECIALITIES = ['syn_flood','port_scan','suspicious']\n",
    "raw_datasets  = [generate_node_dataset(630, seed=i, speciality=SPECIALITIES[i]) for i in range(3)]\n",
    "\n",
    "X_all_raw = np.vstack([d[0] for d in raw_datasets])\n",
    "MU_G  = X_all_raw.mean(0)\n",
    "SIG_G = X_all_raw.std(0)+1e-6\n",
    "\n",
    "node_datasets = [((X-MU_G)/SIG_G, y) for X,y in raw_datasets]\n",
    "X_test_raw, y_test = generate_balanced_test(500, seed=99)\n",
    "X_test = (X_test_raw-MU_G)/SIG_G\n",
    "\n",
    "print('='*64)\n",
    "print('  DATASET SUMMARY')\n",
    "print('='*64)\n",
    "print(f'  Nodes x samples : 3 x 630 = 1890 training total')\n",
    "print(f'  Test set        : 500 (all attack types equally)')\n",
    "print(f'  Features        : 8')\n",
    "print(f'  Label noise     : 10% (train), 5% (test)')\n",
    "for i,((X,y),sp) in enumerate(zip(raw_datasets,SPECIALITIES)):\n",
    "    print(f'  Node {i+1} ({sp:10}): {(y==0).sum()} normal, {(y==1).sum()} attack')\n",
    "print(f'  Test set         : {(y_test==0).sum()} normal, {(y_test==1).sum()} attack')\n",
    "print('='*64)"
   ]
