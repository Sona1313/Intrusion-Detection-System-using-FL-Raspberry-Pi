    "class LightweightMLP:\n",
    "    \"\"\"8->8->1 MLP. 81 params. 324 B storage. ~144 FLOPs/sample.\"\"\"\n",
    "    def __init__(self, seed=None):\n",
    "        rng=np.random.default_rng(seed)\n",
    "        self.W1=rng.standard_normal((8,8))*np.sqrt(2/8); self.b1=np.zeros(8)\n",
    "        self.W2=rng.standard_normal((8,1))*np.sqrt(2/8); self.b2=np.zeros(1)\n",
    "\n",
    "    @staticmethod\n",
    "    def _relu(z):    return np.maximum(0,z)\n",
    "    @staticmethod\n",
    "    def _sigmoid(z): return 1/(1+np.exp(-np.clip(z,-500,500)))\n",
    "    @staticmethod\n",
    "    def _relu_g(z):  return (z>0).astype(float)\n",
    "\n",
    "    def _fwd(self,X):\n",
    "        self._z1=X@self.W1+self.b1; self._a1=self._relu(self._z1)\n",
    "        self._z2=self._a1@self.W2+self.b2; self._a2=self._sigmoid(self._z2)\n",
    "        return self._a2\n",
    "\n",
    "    def predict_proba(self,X): return self._fwd(X).ravel()\n",
    "    def predict(self,X):       return (self.predict_proba(X)>=0.5).astype(int)\n",
    "\n",
    "    def local_train(self,X,y,epochs=5,lr=0.05,batch=32):\n",
    "        N=len(y)\n",
    "        for _ in range(epochs):\n",
    "            perm=np.random.permutation(N)\n",
    "            for s in range(0,N,batch):\n",
    "                b=perm[s:s+batch]; Xb=X[b]; yb=y[b]\n",
    "                self._fwd(Xb); N_b=len(yb)\n",
    "                d2=(self._a2-yb.reshape(-1,1))/N_b\n",
    "                dW2=self._a1.T@d2; db2=d2.sum(0)\n",
    "                d1=(d2@self.W2.T)*self._relu_g(self._z1)\n",
    "                dW1=Xb.T@d1; db1=d1.sum(0)\n",
    "                self.W1-=lr*dW1; self.b1-=lr*db1\n",
    "                self.W2-=lr*dW2; self.b2-=lr*db2\n",
    "\n",
    "    def get_flat(self): return np.concatenate([self.W1.ravel(),self.b1,self.W2.ravel(),self.b2])\n",
    "    def set_flat(self,w):\n",
    "        self.W1=w[:64].reshape(8,8); self.b1=w[64:72]\n",
    "        self.W2=w[72:80].reshape(8,1); self.b2=w[80:81]\n",
    "\n",
    "\n",
    "def eval_metrics(model, X, y):\n",
    "    yp=model.predict(X)\n",
    "    tp=int(((y==1)&(yp==1)).sum()); fp=int(((y==0)&(yp==1)).sum())\n",
    "    fn=int(((y==1)&(yp==0)).sum()); tn=int(((y==0)&(yp==0)).sum())\n",
    "    acc=(tp+tn)/len(y)\n",
    "    prec=tp/(tp+fp) if (tp+fp)>0 else 0\n",
    "    rec =tp/(tp+fn) if (tp+fn)>0 else 0\n",
    "    f1  =2*prec*rec/(prec+rec) if (prec+rec)>0 else 0\n",
    "    loss=-np.mean(y*np.log(model.predict_proba(X)+1e-9)\n",
    "                 +(1-y)*np.log(1-model.predict_proba(X)+1e-9))\n",
    "    return dict(tp=tp,fp=fp,fn=fn,tn=tn,accuracy=acc,\n",
    "                precision=prec,recall=rec,f1=f1,loss=loss)\n",
    "\n",
    "\n",
    "print('MLP architecture: 8->8->1')\n",
    "print('Parameters: 64+8+8+1 = 81')\n",
    "print('Storage (float32): 81 x 4 B = 324 B = 0.316 kB')\n",
    "print('Inference FLOPs: ~144 multiply-adds/sample')"
   ]
